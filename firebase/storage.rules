rules_version = '2';

// ── Reglas de Cloud Storage para HemoPocket ──
// Los PDF se guardan organizados por sección:  guias/{section}/{archivo}.pdf
//   p. ej.  guias/bs/Inmunobanco.pdf  →  pertenece a la sección "bs" (Banco de Sangre)
//
// Lectura: cualquier usuario con sesión iniciada.
// Escritura (subir/sustituir/borrar): admin, o editor de ESA sección.
// Los permisos se leen de Firestore (colección roles), porque las reglas de
// Storage pueden consultar Firestore pero NO la Realtime Database.

service firebase.storage {
  match /b/{bucket}/o {

    function roleData() {
      return firestore.get(/databases/(default)/documents/roles/$(request.auth.uid)).data;
    }
    function hasRole() {
      return request.auth != null
        && firestore.exists(/databases/(default)/documents/roles/$(request.auth.uid));
    }
    function canEdit(section) {
      return (hasRole() && roleData().role == 'admin')
        || (hasRole()
            && roleData().role == 'editor'
            && (roleData().sections is list)
            && (section in roleData().sections));
    }
    // Lectura permitida a usuarios autorizados: admin/editor, cuenta aprobada, o
    // usuario heredado sin ficha (creado en consola antes del sistema de registro).
    function hasApprovedAccount() {
      return request.auth != null
        && firestore.exists(/databases/(default)/documents/cuentas/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/cuentas/$(request.auth.uid)).data.estado == 'aprobada';
    }
    function hasNoAccount() {
      return request.auth != null
        && !firestore.exists(/databases/(default)/documents/cuentas/$(request.auth.uid));
    }
    function isApproved() {
      return hasRole() || hasApprovedAccount() || hasNoAccount();
    }

    match /guias/{section}/{fileName} {
      allow read:  if isApproved();
      allow write: if canEdit(section);
    }
  }
}
